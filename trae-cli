# ─── 主入口 ────────────────────────────────────────────────
def main():
    script_commands = {
        "pages", "use", "reset", "build", "test", "smoke",
        "task-resolve", "resolve", "init-env", "init-wrapper", "help",
    }

    args = parse_args(sys.argv[1:])

    # --json → 动态抑制颜色 + 设置全局 json 模式
    global _JSON_MODE
    if args.json_mode:
        _JSON_MODE = True
        _set_no_color()

    # 全局 flag 优先级: version > schema > man > help
    if args.version:
        if args.json_mode:
            print(json.dumps({"version": "1.0.0"}))
        else:
            print("trae-cli 1.0.0")
        return

    if args.schema:
        print(json.dumps(build_full_schema(), ensure_ascii=False, indent=2))
        return

    if args.man:
        print(MAN_TEXT)
        return

    # --help / -h → @USAGE 速查；help 子命令 → @HELP 日常
    if args.help:
        print(USAGE_TEXT)
        return

    if args.command == "help":
        print(HELP_TEXT)
        return

    cmd = args.command

    # 脚本命令分发
    if cmd == "pages":
        cmd_pages(args)
    elif cmd == "use":
        if not args.extra:
            _err("用法: trae-cli use <编号>", "E1003")
            sys.exit(1)
        args.index = args.extra[0]
        cmd_use(args)
    elif cmd == "reset":
        cmd_reset(args)
    elif cmd == "build":
        cmd_build(args)
    elif cmd == "test":
        cmd_test(args)
    elif cmd == "smoke":
        cmd_smoke(args)
    elif cmd in ("task-resolve", "resolve"):
        args.session = args.extra[0] if args.extra else None
        cmd_task_resolve(args)
    elif cmd == "init-env":
        cmd_init_env(args)
    elif cmd == "init-wrapper":
        cmd_init_wrapper(args)
    else:
        # 透传给 autocli trae-cn
        args.subcmd = cmd
        cmd_passthrough(args)

